<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hrms.system.organization.mapper.DeptMapper">

    <!-- 按祖先路径查询子部门 -->
    <select id="selectChildrenByAncestors" resultType="com.hrms.system.organization.entity.DeptDO">
        SELECT *
        FROM sys_dept
        WHERE ancestors LIKE CONCAT(#{ancestors}, ',%')
          AND is_deleted = 0
        ORDER BY sort_no
    </select>

    <!-- 按部门编码查询 -->
    <select id="selectByDeptCode" resultType="com.hrms.system.organization.entity.DeptDO">
        SELECT *
        FROM sys_dept
        WHERE dept_code = #{deptCode}
          AND is_deleted = 0
        LIMIT 1
    </select>

</mapper>

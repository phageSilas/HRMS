# ========================================
# HRMS 环境变量配置模板
# ========================================
# 使用说明：
# 1. 复制此文件为 .env（不要提交到 Git）
# 2. 根据实际环境修改配置值
# 3. 生产环境必须设置所有标记为【必须】的变量

# ========================================
# JWT 配置【必须】
# ========================================
# JWT 密钥：至少 32 字节，建议使用密钥生成工具
# 生成方式：openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-at-least-32-bytes-long-please-change-this

# JWT 过期时间（毫秒），默认 7 天
JWT_EXPIRATION=604800000

# ========================================
# 数据库配置【必须】
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hrms
DB_USERNAME=root
DB_PASSWORD=your-database-password

# ========================================
# 文件上传配置
# ========================================
# 文件存储路径（Windows 示例）
FILE_UPLOAD_PATH=D:/hrms/files

# 单个文件最大大小（字节），默认 10MB
FILE_MAX_SIZE=10485760

# 允许的文件类型（逗号分隔）
FILE_ALLOWED_TYPES=jpg,jpeg,png,gif,bmp,pdf,doc,docx,xls,xlsx,ppt,pptx,txt

# ========================================
# Redis 配置（可选）
# ========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================================
# RabbitMQ 配置（可选）
# ========================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# ========================================
# 服务端口配置
# ========================================
SERVER_PORT=8080

# ========================================
# 日志配置
# ========================================
LOG_LEVEL=info